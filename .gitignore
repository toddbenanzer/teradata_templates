# .gitignore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Packages / Distribution
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Testing / Coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.ruff_cache/

# Framework specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# Documentation
docs/_build/

# Notebooks
.ipynb_checkpoints

# Environment managers / Tools
.python-version
# .venv/ # Generally ignore local venvs if created
# .env # Ignore environment variable files

# --- IDE / Editor ---
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json
# Keep shared config, ignore user state, etc.

# PyCharm
.idea/

# SublimeText
*.sublime-project
*.sublime-workspace

# Other
.project
.pydevproject
.settings/

# --- OS generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Dev Containers ---
.devcontainer/.cache/
.devcontainer/.history/
# Keep .devcontainer/devcontainer.json (and potentially docker-compose.yml)

# --- Secrets ---
# Ensure you NEVER commit sensitive information!
*.pem
*.key
credentials.*
secrets.*
config.json # If it contains secrets
*.env # Double-check environment files don't contain secrets